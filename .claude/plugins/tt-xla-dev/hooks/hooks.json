{
  "description": "tt-xla-dev plugin hooks — validates commit messages after git commit calls",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/validate-commit.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

{
    "version": 4,
    "configurePresets": [
      {
        "name": "debug",
        "displayName": "Debug and custom flags",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "CMAKE_C_COMPILER": "clang",
          "CMAKE_CXX_COMPILER": "clang++",
          "CMAKE_C_COMPILER_LAUNCHER": "ccache",
          "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
          "TT_RUNTIME_DEBUG": "ON",
          "TTMLIR_BUILD_TYPE": "Debug"
        }
      },
      {
        "name": "debug-with-ttrt",
        "displayName": "Debug and custom flags",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "CMAKE_C_COMPILER": "clang",
          "CMAKE_CXX_COMPILER": "clang++",
          "CMAKE_C_COMPILER_LAUNCHER": "ccache",
          "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
          "TT_RUNTIME_DEBUG": "ON",
          "TTMLIR_BUILD_TYPE": "Debug",
          "TTXLA_ENABLE_TTRT": "ON"
        }
      },
      {
        "name": "release",
        "displayName": "Release and custom flags",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Release",
          "CMAKE_C_COMPILER": "clang-20",
          "CMAKE_CXX_COMPILER": "clang++-20",
          "CMAKE_C_COMPILER_LAUNCHER": "ccache",
          "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
          "TTMLIR_BUILD_TYPE": "Release",
          "TT_RUNTIME_DEBUG": "OFF"
        }
      }
    ]
}
